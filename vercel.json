{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/calendar-sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/webhooks-retry",
      "schedule": "*/5 * * * *"
    }
  ]
}
