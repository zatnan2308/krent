# ============================================================
#  Krent - Environment Variables
#  Copy to .env.local and fill in values for local development.
#  Variables are validated by src/lib/env.ts as each module is
#  wired in. Never commit .env.local - only this example file.
# ============================================================

# ---- Application -------------------------------------------
NEXT_PUBLIC_APP_NAME=Krent
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase ----------------------------------------------
# URL and anon key are public (safe in the browser bundle).
NEXT_PUBLIC_SUPABASE_URL=https://pclhwbgsxdztriqdtosg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key - SERVER ONLY. Bypasses RLS. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (payments module) ------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- PayPal (payments module) ------------------------------
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ---- Crypto payments (optional module) ---------------------
CRYPTO_PAYMENTS_PROVIDER=
CRYPTO_PAYMENTS_API_KEY=

# ---- Resend (transactional email) --------------------------
RESEND_API_KEY=
EMAIL_FROM=

# ---- Google integrations -----------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_CONTAINER_ID=
GOOGLE_SEARCH_CONSOLE_SITE_URL=
GOOGLE_ADS_DEVELOPER_TOKEN=

# ---- Meta integrations -------------------------------------
NEXT_PUBLIC_META_PIXEL_ID=
META_APP_ID=
META_APP_SECRET=
META_CONVERSIONS_API_TOKEN=

# ---- Build / CI --------------------------------------------
# Set to "true" to skip env validation during builds.
SKIP_ENV_VALIDATION=
